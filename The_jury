فقط به این علت سیاهچاله های ستاره های بسیار بزرگ ، بزرگتر میشوند ، چون مواد زیادی برای بلعیدن بعد از انفجار برایشان باقی میماند بعد از تولد 

import numpy as np

class AlgebraicCosmos:
    def __init__(self, anchor=1.0):
        self.anchor = anchor
        self.c0 = 299792458  # سرعت نور در خلاء (متر بر ثانیه)
        self.rho_crit = 1017  # چگالی بحرانی گراویتونی (مدل ستاره نوترونی/سیاهچاله)

    def r_law(self, x):
        """قانون بازتاب ساختاری حول لنگر"""
        return 2 * self.anchor - x

    def time_dilation_factor(self, rho):
        """محاسبه نرخ جریان زمان (Tau) بر اساس غلظت بافت"""
        # Tau = 1 (زمان عادی)، Tau = 0 (توقف مطلق زمان)
        tau = np.exp(-rho / (self.rho_crit / 10))
        return np.clip(tau, 0, 1)

    def local_light_speed(self, tau):
        """سرعت نور محلی که تابع نرخ زمان است"""
        return self.c0 * tau

    def simulate_star_evolution(self, initial_mass, radius_steps):
        """شبیه سازی زایش سیاهچاله از پیله پلاسمایی"""
        print(f"{'Radius (km)':<15} | {'Density (rho)':<15} | {'Time Rate (Tau)':<15} | {'Status':<15}")
        print("-" * 70)
        
        for r in radius_steps:
            # محاسبه چگالی بافت (فرمول ساده شده برای داده عددی)
            volume = (4/3) * np.pi * (r * 1000)3
            rho = initial_mass / volume
            
            tau = self.time_dilation_factor(rho)
            v_l = self.local_light_speed(tau)
            
            # تعیین وضعیت بر اساس غلظت بافت
            if tau < 0.01:
                status = "BLACK HOLE (Butterfly)"
            elif tau < 0.5:
                status = "NEUTRON/PULSAR"
            elif tau < 0.9:
                status = "WHITE DWARF"
            else:
                status = "STAR (Caterpillar)"
                
            print(f"{r:<15.2f} | {rho:<15.2e} | {tau:<15.4f} | {status:<15}")

# --- اجرای شبیه سازی عددی ---
# فرض کنیم جرمی معادل 3 برابر خورشید داریم
mass_sun = 1.989 * 10**30
star_mass = 3 * mass_sun

# شعاع هایی از 10,000 کیلومتر تا 3 کیلومتر (نقطه زایش)
radii = [10000, 5000, 1000, 500, 100, 50, 15, 6, 3]

cosmos = AlgebraicCosmos()
cosmos.simulate_star_evolution(star_mass, radii)

